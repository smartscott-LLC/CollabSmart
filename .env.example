# CollabSmart Environment Configuration
# Copy this to .env and fill in your values
#
# ⚠  PASSWORDS: Change every *_PASSWORD value before exposing this stack to a
#    network.  The defaults work out-of-the-box for local dev but are not
#    suitable for production.
#
# ⚠  VOLUME RESET: If you change POSTGRES_PASSWORD after the postgres volume
#    has already been created, postgres will reject logins until the volume is
#    reset.  To reset (destroys all stored data):
#        docker compose down -v
#    Then restart with the new password.

# ── Anthropic (required when AI_PROVIDER=anthropic) ──────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── AI Provider & Model ───────────────────────────────────────────────────────
# Provider to use for all AI responses.  Supported values:
#   anthropic   — Anthropic Claude  (ANTHROPIC_API_KEY required)
#   openai      — OpenAI GPT        (AI_API_KEY required)
#   ollama      — Local Ollama      (FREE — no key required; set AI_BASE_URL)
#   groq        — Groq              (FREE tier — AI_API_KEY required)
#   openrouter  — OpenRouter        (FREE models available — AI_API_KEY required)
#   together_ai — Together AI       (FREE tier — AI_API_KEY required)
# Can also be changed at runtime in the Settings panel.
AI_PROVIDER=anthropic

# Generic API key used by non-Anthropic providers (OpenAI, Groq, OpenRouter, Together AI).
# Leave blank for Ollama (no key required).
AI_API_KEY=

# Optional base URL override.  Defaults are auto-detected per provider.
# Examples:
#   Ollama:     http://localhost:11434/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   LM Studio:  http://localhost:1234/v1
AI_BASE_URL=

# Model used for all AI responses.  Can also be changed at runtime in Settings.
# Examples:
#   Anthropic:  claude-haiku-4-5-20251001
#   OpenAI:     gpt-4o-mini
#   Ollama:     llama3.2  (must be pulled first: `ollama pull llama3.2`)
#   Groq:       llama-3.1-8b-instant
#   OpenRouter: meta-llama/llama-4-maverick:free
AI_MODEL=claude-haiku-4-5-20251001
AI_MAX_TOKENS=4096

# ── Backend server ────────────────────────────────────────────────────────────
PORT=3001
# Path mounted as the shared workspace inside backend and desktop containers.
WORKSPACE_PATH=/workspace

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_NOVNC_URL=http://localhost:6080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=collabsmart
POSTGRES_USER=collabsmart
# ⚠  Change for production.  Must match the password used when the volume was
#    first created (see volume-reset note above).
POSTGRES_PASSWORD=collabsmart

# ── Dragonfly Cache (Redis-compatible) ────────────────────────────────────────
DRAGONFLY_HOST=dragonfly
DRAGONFLY_PORT=6379
# ⚠  Change for production.
DRAGONFLY_PASSWORD=dragonfly_secret
DRAGONFLY_DB=0
# Max memory Dragonfly may use (e.g. 256mb, 1gb).
DRAGONFLY_MAX_MEMORY=512mb

# ── noVNC / Desktop ───────────────────────────────────────────────────────────
# Password required to connect to the shared desktop via noVNC.
# ⚠  Change for production.
VNC_PASSWORD=collabsmart_vnc

# ── O*NET Web Services (optional — enables occupation-aware AI context) ───────
# Register at: https://services.onetcenter.org/
# Set ONET_ENABLED=true in the Settings panel (or below) after adding credentials.
ONET_API_BASE=https://services.onetcenter.org/ws
ONET_USERNAME=
ONET_PASSWORD=

# ── Memory System ─────────────────────────────────────────────────────────────
# Promotion threshold: messages with importance >= this score go to long-term memory
# Valid range: 0.0–10.0 (default: 5.0)
MEMORY_PROMOTION_THRESHOLD=5.0
# Hours before Dragonfly working-memory entries expire (default: 48)
WORKING_MEMORY_TTL_HOURS=48

# ── Agent Factory & Tool Pattern Memory ───────────────────────────────────────
# Enable/disable the specialized agent factory (injects domain-expert context).
AGENT_FACTORY_ENABLED=true
# Enable/disable tool success pattern memory (learn and replay proven tool sequences).
TOOL_PATTERN_MEMORY_ENABLED=true
# Discard tool patterns older than this many days (0 = never discard).
MAX_TOOL_PATTERN_AGE_DAYS=30

# ── Session ───────────────────────────────────────────────────────────────────
# Record full session transcripts so they can be replayed from the Settings panel.
SESSION_RECORDING_ENABLED=false
# Maximum in-memory conversation turns kept per session.
MAX_CONVERSATION_HISTORY=100

# ── Feedback ──────────────────────────────────────────────────────────────────
# Allow users to submit explicit ratings via POST /api/feedback.
FEEDBACK_COLLECTION_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
